{
  "name": "mews-mcp",
  "version": "1.1.2",
  "description": "Model Context Protocol server for Mews API integration",
  "main": "dist/index.js",
  "module": "./src/index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzgael/mews-mcp.git"
  },
  "homepage": "https://github.com/zzgael/mews-mcp#readme",
  "bugs": {
    "url": "https://github.com/zzgael/mews-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsx watch src/index.ts",
