  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@smithery/sdk": "^1.5.5",
    "littlesis-mcp": "^1.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "jest": "^29.7.0",
    "semantic-release": "^24.2.7",
    "ts-jest": "^29.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "bin": {
    "mews-mcp": "./dist/index.js"
  }
